{
  "name": "@slashand/sdui-blade-react",
  "version": "1.0.0-alpha.4",
  "description": "React SDUI rendering wrapper for the Agnostic Blade System.",
  "author": "Slashand LLC",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "sdui",
    "server-driven-ui",
    "react",
    "blade-system",
    "json-ui",
    "azure-portal",
    "ibiza-shell",
    "micro-frontends",
    "journey-protocol"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@slashand/sdui-blade-core": "^1.0.0-alpha.4",
    "clsx": "latest",
    "framer-motion": ">=10.0.0",
    "lucide-react": "latest",
    "tailwind-merge": "latest"
  },
  "peerDependencies": {
    "@slashand/sdui-blade-core": "^1.0.0-alpha.4",
    "framer-motion": ">=10.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "zustand": ">=4.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
